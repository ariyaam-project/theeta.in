# Shared local Docker settings. Copy to .env before running docker compose.

SERVICE_TOKEN=local-development-token

# Google OAuth for the Cloudflare Worker API.
# Redirect URI: https://aerosol-reformer-twirl.ngrok-free.dev/api/auth/google/callback
APP_URL=https://aerosol-reformer-twirl.ngrok-free.dev
FRONTEND_URL=http://localhost:3000
FASTAPI_WORKER_URL=http://192.168.10.101:8001
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Required for AI location extraction. Leave empty only if you are testing API/web
# without processing real reel jobs.
OPENAI_API_KEY=
OPENAI_LOCATION_MODEL=gpt-5.4-mini
TRANSCRIPTION_PROVIDER=openai
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_TRANSCRIPTION_LANGUAGE=
OPENAI_TRANSCRIPTION_PROMPT=The audio is primarily Malayalam from Kerala food reels, sometimes mixed with English. Transcribe Malayalam words accurately and do not convert them to Kannada script.

POLL_ENABLED=false
POLL_INTERVAL_SECONDS=5

WHISPER_MODEL=medium
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
MAX_DURATION_SECONDS=180
MAX_DOWNLOAD_MB=100

LOCATION_ACCEPT_THRESHOLD=0.85
LOCATION_MARGIN_THRESHOLD=0.20
MAX_LOCATION_COMMENTS=50

# Optional: path inside the worker container to a Netscape-format Instagram
# cookies file. If needed, also mount that file in docker-compose.yml.
COOKIES_FILE=

# Production-only when using docker-compose.prod.yml.
API_BASE_URL=https://api.example.com
THETA_WORKER_TAG=latest
