OPENAI_API_KEY=
API_BASE_URL=https://aerosol-reformer-twirl.ngrok-free.dev
OPENAI_LOCATION_MODEL=gpt-5.4-mini
TRANSCRIPTION_PROVIDER=openai
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_TRANSCRIPTION_LANGUAGE=
OPENAI_TRANSCRIPTION_PROMPT=The audio is primarily Malayalam from Kerala food reels, sometimes mixed with English. Transcribe Malayalam words accurately and do not convert them to Kannada script.
WHISPER_MODEL=medium
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
POLL_ENABLED=false

LOCATION_ACCEPT_THRESHOLD=0.85
LOCATION_MARGIN_THRESHOLD=0.20
MAX_LOCATION_COMMENTS=50

# Optional if ffmpeg is not on PATH.
FFMPEG_LOCATION=
